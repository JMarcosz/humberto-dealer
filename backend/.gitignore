# ===========================================================
# .gitignore — Monorepo Concesionaria (Next.js + Flask + MySQL)
# ===========================================================

# ----- Variables de entorno (NUNCA commitear) -----
.env
.env.local
.env.*.local
*.env

# ----- Python / Flask -----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.egg-info/
.eggs/
instance/
.flask_session/

# ----- Node / Next.js -----
node_modules/
.next/
out/
build/
.turbo/
.pnpm-store/
.pnp.*
.yarn/cache/
.yarn/build-state.log
.yarn/install-state.gz

# ----- v0 sandbox internals (del frontend original) -----
__v0_runtime_loader.js
__v0_devtools.tsx
__v0_jsx-dev-runtime.ts
.snowflake/
.v0-trash/
.vercel/

# ----- Subidas de archivos en runtime -----
uploads/
tmp/
*.xlsx.tmp

# ----- IDEs -----
.idea/
.vscode/
*.swp
*.swo
*~

# ----- OS junk -----
.DS_Store
Thumbs.db
desktop.ini

# ----- Logs -----
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ----- Bases de datos locales -----
*.db
*.sqlite
*.sqlite3
