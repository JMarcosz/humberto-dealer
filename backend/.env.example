# =============================================================
# CONCESIONARIA — Variables de entorno
# Copiar a .env y completar valores reales. NUNCA commitear .env.
# =============================================================

# Flask
FLASK_ENV=development           # development | production
FLASK_DEBUG=1                   # IMPORTANTE: poner 0 en producción
SECRET_KEY=cambia-esto-por-un-valor-seguro-min-64-chars-aleatorio

# URL del frontend (cambiar al dominio real en producción)
FRONTEND_URL=http://localhost:3000

# Base de datos MySQL
DB_USER=root
DB_PASSWORD=tu_password_aqui
DB_HOST=localhost
DB_PORT=3306
DB_NAME=concesionaria
SQLALCHEMY_ECHO=0               # 1 para ver queries en consola

# WhatsApp Business API (Meta Cloud API)
# Obtener en: https://developers.facebook.com/apps
WHATSAPP_API_KEY=EAAxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_VERIFY_TOKEN=token_secreto_para_verificacion_webhook

# Google OAuth 2.0
# Obtener en: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxx

# Ubicación del dealer (lat/lng)
DEALER_LAT=18.4861
DEALER_LNG=-69.9312
DEALER_PLACE=Piantini, Santo Domingo, República Dominicana

# Subidas de archivos (opcional — por defecto usa backend/uploads/)
# UPLOAD_FOLDER=/ruta/personalizada/uploads
