# =============================================================
# BACKEND — Variables de entorno
# Copia este archivo como .env y completa los valores reales.
# NUNCA commitear el .env con valores reales.
# =============================================================

# ── Flask ─────────────────────────────────────────────────────
# Valores: development | production
FLASK_ENV=development
# 1 en desarrollo, 0 en producción
FLASK_DEBUG=1
# URL pública del frontend (para CORS y redirecciones OAuth)
FRONTEND_URL=http://localhost:3000
# Clave secreta larga y aleatoria — genera con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ── Base de datos MySQL ───────────────────────────────────────
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=
DB_NAME=concesionaria
# 1 para ver queries en consola (solo desarrollo)
SQLALCHEMY_ECHO=0

# ── WhatsApp Business API (Meta Cloud API) ────────────────────
# Obtener en: https://developers.facebook.com/apps → tu app → WhatsApp → API Setup
# Recomendado: usar token de System User permanente (no expira)
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=
# Token que tú inventas — debe coincidir con el configurado en Meta Webhook
WHATSAPP_VERIFY_TOKEN=
# Número del dueño/asesor que recibe notificaciones internas (sin + ni espacios)
WHATSAPP_OWNER_NUMBER=

# ── Google OAuth 2.0 ──────────────────────────────────────────
# Obtener en: https://console.cloud.google.com/apis/credentials
# Dejar vacío para desactivar login con Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Solo desarrollo — permite OAuth sobre HTTP (quitar en producción)
OAUTHLIB_INSECURE_TRANSPORT=1

# ── Ubicación del dealer ──────────────────────────────────────
DEALER_LAT=
DEALER_LNG=
DEALER_PLACE=
DEALER_ADDRESS=

# ── Bot de WhatsApp ───────────────────────────────────────────
# URL pública del catálogo (enviada por el bot a los clientes)
CATALOG_URL=
# Shortlink de Google Maps para la ubicación
GOOGLE_MAPS_LINK=

# ── Archivos subidos ──────────────────────────────────────────
# Opcional — por defecto usa backend/uploads/
# UPLOAD_FOLDER=/ruta/personalizada/uploads
