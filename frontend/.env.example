# =============================================================
# FRONTEND — Variables de entorno
# Copia este archivo como .env y completa los valores reales.
# NUNCA commitear el .env con valores reales.
# =============================================================

# ── API ───────────────────────────────────────────────────────
# Ruta del proxy Next.js (no cambiar en desarrollo local)
NEXT_PUBLIC_API_URL=/api

# URL absoluta al backend Flask (usada por SSR y el rewrite de Next.js)
# Desarrollo: http://localhost:5001/api
# Producción: URL de tu backend en Railway/Render/etc.
BACKEND_URL=https://tu-backend.railway.app/api

# ── Contacto ──────────────────────────────────────────────────
# Número sin prefijo + ni espacios (solo dígitos)
NEXT_PUBLIC_PHONE_NUMBER=
# Número formateado para mostrar al usuario
NEXT_PUBLIC_PHONE_FORMATTED=
NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_BUSINESS_ADDRESS=

# ── Redes sociales ────────────────────────────────────────────
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_TIKTOK_URL=
# Link directo de WhatsApp con mensaje pre-escrito
NEXT_PUBLIC_WHATSAPP_LINK=

# ── Navegación / Ubicación ────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_URL=
NEXT_PUBLIC_WAZE_URL=
