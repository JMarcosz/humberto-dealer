# =============================================================
# FRONTEND — Variables de entorno
# Copiar a .env.local y ajustar valores. NUNCA commitear .env.local.
# =============================================================

# URL base de la API Flask. En desarrollo local apunta a localhost:5000.
# En producción, apuntar al dominio del backend (ej: https://api.tudominio.com/api).
NEXT_PUBLIC_API_URL=/api

# URL pública del frontend (usada por sitemap.ts y SEO).
BACKEND_URL=https://humberto-dealer.onrender.com/api
